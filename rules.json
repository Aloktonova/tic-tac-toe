{
  "rules": {
    "users": {
      "$userId": {
        ".read": "$userId === auth.uid || auth !== null",
        ".write": false,
        "name": {
          ".write": "$userId === auth.uid"
        },
        "language": {
          ".write": "$userId === auth.uid"
        },
        "lastActive": {
          ".write": "$userId === auth.uid"
        },
        "unlockedWallpapers": {
          ".read": "$userId === auth.uid",
          ".write": false
        },
        "coins": {
          ".read": "$userId === auth.uid",
          ".write": false
        },
        "wins": {
          ".read": true,
          ".write": false
        },
        "losses": {
          ".read": "$userId === auth.uid",
          ".write": false
        },
        "xp": {
          ".read": "$userId === auth.uid",
          ".write": false
        }
      }
    },
    "rooms": {
      "$roomId": {
        ".read": true,
        ".write": "auth !== null"
      }
    },
    "queue": {
      "$userId": {
        ".read": true,
        ".write": "$userId === auth.uid"
      }
    },
    "payments": {
      ".read": false,
      ".write": false
    },
    "leaderboard": {
      ".read": true,
      ".write": false
    }
  }
}
