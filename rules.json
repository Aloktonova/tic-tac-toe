{
  "rules": {
    "users": {
      "$userId": {
        ".read": "$userId === auth.uid || auth !== null",
        ".write": false,
        "name": {
          ".write": "$userId === auth.uid"
        },
        "language": {
          ".write": "$userId === auth.uid"
        },
        "lastActive": {
          ".write": "$userId === auth.uid"
        },
        "unlockedWallpapers": {
          ".read": "$userId === auth.uid",
          ".write": false
        },
        "coins": {
          ".read": "$userId === auth.uid",
          ".write": false
        },
        "wins": {
          ".read": true,
          ".write": false
        },
        "losses": {
          ".read": "$userId === auth.uid",
          ".write": false
        },
        "xp": {
          ".read": "$userId === auth.uid",
          ".write": false
        }
      }
    },
    "rooms": {
      "$roomId": {
        ".read": true,
        ".write": "auth !== null"
      }
    },
    "queue": {
      "$userId": {
        ".read": true,
        ".write": "$userId === auth.uid"
      }
    },
    "payments": {
      ".read": false,
      ".write": false
    },
    "leaderboard": {
      ".read": true,
      ".write": false
    },
    "tournaments": {
      ".read": true,
      "current": {
        ".read": true,
        ".write": "auth !== null",
        "players": {
          "$userId": {
            ".read": true,
            ".write": "auth !== null",
            "uid": { ".write": "$userId === auth.uid" },
            "name": { ".write": "$userId === auth.uid" },
            "wins": { ".write": false },
            "losses": { ".write": false },
            "draws": { ".write": false },
            "best_streak": { ".write": false },
            "joinedAt": { ".write": "$userId === auth.uid" }
          }
        },
        "leaderboard": {
          ".read": true,
          ".write": "auth !== null",
          ".indexOn": ["points", "updatedAt"],
          "$userId": {
            ".read": true,
            ".write": "auth !== null"
          }
        }
      },
      "history": {
        ".read": true,
        ".write": "auth !== null"
      }
    }
  }
}
