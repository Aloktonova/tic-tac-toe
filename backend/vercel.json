{
  "version": 2,
  "env": {
    "WEBHOOK_SECRET": "<set-in-vercel-project-env>",
    "NVIDIA_API_KEY": "<set-in-vercel-project-env>"
  },
  "crons": [
    {
      "path": "/api/daily-broadcast",
      "schedule": "0 9 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/api/create-invoice",
      "dest": "/api/create-invoice.js"
    },
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js"
    },
    {
      "src": "/api/check-channel",
      "dest": "/api/check-channel.js"
    },
    {
      "src": "/api/daily-broadcast",
      "dest": "/api/daily-broadcast.js"
    },
    {
      "src": "/api/ai-generate",
      "dest": "/api/ai-generate.js"
    }
  ]
}
